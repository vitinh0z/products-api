{
  "name": "estudosnode",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-esm -d src/infrastructure/database/typeorm/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create src/infrastructure/database/typeorm/migrations/CreateMigration",
    "migration:generate": "npm run typeorm -- migration:generate src/infrastructure/database/typeorm/migrations/AutoMigration",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typeorm-ts-node-esm": "^0.3.20",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}
